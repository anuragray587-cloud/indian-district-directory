"history": {
  "historicalImportance": "Patna is one of the oldest continuously inhabited cities in the world. It was known as Pataliputra in ancient times and served as the capital of several powerful Indian empires including the Maurya, Gupta and Pala dynasties. Today it is the capital of Bihar and an important political, educational and cultural centre of eastern India.",

  "formationHistory": "The present Patna district was formed during the British period. After the creation of the Province of Bihar and Orissa in 1912, Patna became the provincial capital. Following the separation of Bihar and Orissa in 1936, Patna continued as the capital of Bihar.",

  "freedomMovement": "Patna played a significant role in India's freedom movement. Mahatma Gandhi launched important phases of the Champaran Satyagraha from Patna, and the city witnessed major participation during the Non-Cooperation Movement, Civil Disobedience Movement and Quit India Movement.",

  "archaeologicalImportance": "Patna possesses immense archaeological significance due to the remains of ancient Pataliputra. Excavations at Kumhrar have revealed the remains of the Mauryan palace, assembly hall and other ancient structures.",

  "asiProtectedMonuments": [
    "Agam Kuan",
    "Kumhrar Archaeological Site",
    "Didarganj Yakshi"
  ],

  "historicalTimeline": [
    "5th century BCE - Pataliputra established as the capital of Magadha.",
    "322 BCE - Became the capital of the Maurya Empire under Chandragupta Maurya.",
    "3rd century BCE - Emperor Ashoka ruled from Pataliputra.",
    "4th-6th century CE - Flourished under the Gupta Empire.",
    "1912 - Patna became the capital of the Province of Bihar and Orissa.",
    "1936 - Patna became the capital of the separate state of Bihar.",
    "1947 - Patna became part of independent India."
  ]
},

